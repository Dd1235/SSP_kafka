    {
      "id": "_ESvpVuUXWWa-JmnSRywl",
      "type": "text",
      "x": -6724.482811887334,
      "y": -4093.307529809582,
      "width": 597.6019897460938,
      "height": 181.51243387771967,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6e",
      "roundness": null,
      "seed": 1972436525,
      "version": 562,
      "versionNonce": 2025631405,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1778319923209,
      "link": null,
      "locked": false,
      "text": "read msg → record latency → time.Sleep(4ms) → next msg\n1000 ms / 4 ms => 250 messages per sec\n12 partitions\nexpect 3000 messages per second, but time.sleep(4) is not\nexactly 4 ms, it is more than that\nput it back in equation to get sleep is actually about 6 ms\n",
      "fontSize": 20.744278157453675,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "read msg → record latency → time.Sleep(4ms) → next msg\n1000 ms / 4 ms => 250 messages per sec\n12 partitions\nexpect 3000 messages per second, but time.sleep(4) is not\nexactly 4 ms, it is more than that\nput it back in equation to get sleep is actually about 6 ms\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
