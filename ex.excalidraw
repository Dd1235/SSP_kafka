      "boundElements": [],
      "updated": 1778321289019,
      "link": null,
      "locked": false,
      "text": "Go sync/atomic\n\nsequential consistency\n\nsame idea as\nmemory_order_seq_cst\n\nstrongest ordering\n\ncompiler emits:\nDMB ISH\nLDAR\nSTLR",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "oaVa7dYwOjFTIt2PfCmsu",
      "originalText": "Go sync/atomic\n\nsequential consistency\n\nsame idea as\nmemory_order_seq_cst\n\nstrongest ordering\n\ncompiler emits:\nDMB ISH\nLDAR\nSTLR",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
