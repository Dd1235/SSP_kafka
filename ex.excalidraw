      "isDeleted": false,
      "boundElements": [],
      "updated": 1778321289019,
      "link": null,
      "locked": false,
      "text": "ARMv8\nApple M2\n\nweaker memory ordering\n\nloads and stores\nmay reorder\n\natomic.Add uses\nLDADDAL\n\nor older\nLDXR / STXR retry\nloops",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "wSq8HyucBRIH47fZmQsrH",
      "originalText": "ARMv8\nApple M2\n\nweaker memory ordering\n\nloads and stores\nmay reorder\n\natomic.Add uses\nLDADDAL\n\nor older\nLDXR / STXR retry loops",
      "autoResize": true,
      "lineHeight": 1.25
    },
